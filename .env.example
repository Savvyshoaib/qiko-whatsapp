# --- Meta WhatsApp Cloud API ---
# From Meta Developer → App → WhatsApp → API Setup
META_ACCESS_TOKEN=your_permanent_or_system_user_token
META_APP_SECRET=your_app_secret
META_VERIFY_TOKEN=use-a-long-random-string-for-webhook-verify
META_PHONE_NUMBER_ID=your_phone_number_id
META_GRAPH_API_VERSION=v21.0

# Public URL of this service (Render sets RENDER_EXTERNAL_URL automatically)
# WHATSAPP_APP_URL=https://qiko-whatsapp-app.onrender.com

PORT=3002

# --- Qiko API (same as Slack app) ---
QIKO_API_BASE_URL=https://stage-backend.qiko.ai/api/avatar
QIKO_WEB_ORIGIN=https://stage-app.qiko.ai

# Optional: link sent in welcome message
QIKO_WEB_APP_URL=https://stage-app.qiko.ai
